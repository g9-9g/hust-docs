# Base URL Axios sẽ gọi tới backend.
# Dev: để trống hoặc "/api" để dùng Vite proxy (proxy đang trỏ tới VITE_API_PROXY_TARGET).
# Prod: đặt URL tuyệt đối tới server đã deploy, ví dụ https://api.hust-docs.example.com/api
VITE_API_BASE_URL=http://localhost:4000/api

# Target Vite dev-server proxy chuyển tiếp request /api tới backend (chỉ dùng ở dev).
VITE_API_PROXY_TARGET=http://localhost:4000

# Azure AD (Microsoft) OAuth — phải khớp với app registration trên Azure Portal.
# Tenant ID & Client ID lấy từ Azure Portal -> App registrations.
# Redirect URI phải được khai báo dưới mục "Single-page application".
VITE_AZURE_TENANT_ID=
VITE_AZURE_CLIENT_ID=
VITE_AZURE_REDIRECT_URI=http://localhost:5173
