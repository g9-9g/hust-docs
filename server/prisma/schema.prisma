// Prisma schema for hust-docs (MongoDB)
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

enum Role {
  user
  admin
}

enum DocumentCategory {
  LECTURE_SLIDE
  PAST_EXAM
  SOLUTION
  NOTE
  PROJECT_SAMPLE
  REFERENCE
  LAB_REPORT
  OTHER
}

enum DocumentStatus {
  public
  pending
  hidden
  deleted
}

enum VoteType {
  UP
  DOWN
  NONE
}

enum PointReason {
  UPVOTE_RECEIVED
  DOWNLOAD_MILESTONE
  UPLOAD_DOCUMENT
  REDEEM_REWARD
}

enum GiftType {
  BADGE
  AVATAR_FRAME
  VOUCHER
  OFFLINE_GIFT
  OTHER
}

enum GiftStatus {
  active
  hidden
  out_of_stock
}

enum RedemptionStatus {
  pending
  completed
  cancelled
}

model User {
  id                  String     @id @default(auto()) @map("_id") @db.ObjectId
  fullName            String
  // MSSV 8-9 chữ số trích từ tên hiển thị Microsoft (vd "Nguyen Le Minh 20225651" -> "20225651").
  // Optional vì user cũ chưa parse, hoặc user không có MSSV trong tên hiển thị.
  studentId           String?
  username            String     @unique
  email               String     @unique
  passwordHash        String?
  // Không dùng @unique để tránh xung đột null-duplicate trên các user cũ chưa link Microsoft.
  // Uniqueness kiểm soát ở tầng app khi find-or-create theo (microsoftId | email).
  microsoftId         String?
  role                Role       @default(user)
  avatarUrl           String?
  contributionPoints  Int        @default(0)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  equippedBadgeGiftId String?    @db.ObjectId
  equippedFrameGiftId String?    @db.ObjectId

  documents           Document[] @relation("UploaderDocuments")
  votes               Vote[]
  comments            Comment[]
  pointsTransactions  PointsTransaction[]
  giftRedemptions     GiftRedemption[]

  @@index([microsoftId])
}

model Major {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  code      String     @unique
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  subjects  Subject[]
  documents Document[]
}

model Subject {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  code      String
  name      String
  majorId   String     @db.ObjectId
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  major     Major      @relation(fields: [majorId], references: [id])
  documents Document[]

  @@unique([code, majorId])
  @@index([majorId])
}

model Document {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  description    String           @default("")
  subjectId      String           @db.ObjectId
  majorId        String           @db.ObjectId
  category       DocumentCategory
  tags           String[]         @default([])
  teacherName    String?
  semester       String?
  academicYear   String?

  uploaderId     String           @db.ObjectId

  originalName   String
  storedName     String
  path           String
  mimeType       String
  size           Int
  extension      String

  extraPaths     String[]         @default([])
  extraOriginalNames String[]     @default([])

  previewPath     String?
  previewMimeType String?

  viewCount      Int              @default(0)
  downloadCount  Int              @default(0)
  upvoteCount    Int              @default(0)
  downvoteCount  Int              @default(0)

  qualifiedDownloadCount   Int      @default(0)
  downloadMilestoneAwarded Int      @default(0)

  status         DocumentStatus   @default(public)
  isVerified     Boolean          @default(false)

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  uploader       User             @relation("UploaderDocuments", fields: [uploaderId], references: [id])
  subject        Subject          @relation(fields: [subjectId], references: [id])
  major          Major            @relation(fields: [majorId], references: [id])
  votes          Vote[]
  comments       Comment[]
  downloads      DocumentDownload[]
  views          DocumentView[]

  @@index([subjectId])
  @@index([majorId])
  @@index([uploaderId])
  @@index([category])
  @@index([status])
}

model Vote {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  documentId   String   @db.ObjectId
  type         VoteType
  pointAwarded Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  document Document @relation(fields: [documentId], references: [id])

  @@unique([userId, documentId])
  @@index([documentId])
}

model PointsTransaction {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  userId     String      @db.ObjectId
  amount     Int
  reason     PointReason
  documentId String?     @db.ObjectId
  voterId    String?     @db.ObjectId
  note       String?
  createdAt  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Gift {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  description   String     @default("")
  type          GiftType
  pointsCost    Int
  stock         Int?
  status        GiftStatus @default(active)
  icon          String?
  accentColor   String?
  frameGradient String?
  imageUrl      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  redemptions   GiftRedemption[]
}

model GiftRedemption {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  userId      String           @db.ObjectId
  giftId      String           @db.ObjectId
  giftName    String
  giftType    GiftType
  pointsSpent Int
  status      RedemptionStatus
  usedAt      DateTime?
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])
  gift Gift @relation(fields: [giftId], references: [id])

  @@index([userId])
}

model Comment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  documentId String   @db.ObjectId
  userId     String   @db.ObjectId
  parentId   String?  @db.ObjectId
  content    String
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  document Document  @relation(fields: [documentId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies  Comment[] @relation("CommentReplies")

  @@index([documentId, createdAt])
  @@index([parentId])
  @@index([userId])
}

model DocumentDownload {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  documentId String   @db.ObjectId
  userId     String?  @db.ObjectId
  dedupKey   String
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id])

  @@unique([documentId, dedupKey])
  @@index([documentId])
}

model DocumentView {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  documentId String   @db.ObjectId
  userId     String?  @db.ObjectId
  dedupKey   String                    // "u:<userId>:<YYYY-MM-DD>" hoặc "ip:<sha256(ip)>:<YYYY-MM-DD>"
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id])

  @@unique([documentId, dedupKey])      // mỗi định danh chỉ tính 1 lượt xem / tài liệu / ngày
  @@index([documentId])
}
