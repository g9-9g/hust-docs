PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/hust_docs?replicaSet=rs0&directConnection=true
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50
CLIENT_ORIGIN=http://localhost:5173,https://hust-docs.vercel.app
# Đường dẫn tới binary LibreOffice (để convert .ppt/.pptx sang PDF preview).
# Để trống nếu lệnh `soffice` đã có trong PATH.
LIBREOFFICE_PATH=soffice
LIBREOFFICE_TIMEOUT_MS=120000
# Azure AD (Microsoft) OAuth — chỉ cho phép sinh viên HUST đăng nhập.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
ALLOWED_EMAIL_DOMAIN=sis.hust.edu.vn
